@using System.Security.Claims
@{
    ViewBag.Title = "Dashboard";
    var userName = (User.Identity as ClaimsIdentity)?.FindFirst(ClaimTypes.GivenName)?.Value ?? User.Identity?.Name ?? "User";
    var userRole = (User.Identity as ClaimsIdentity)?.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var isAdmin = userRole == "Admin" || userRole == "SuperAdmin";
}

<!-- Hero -->
<div class="ha-hero mb-4">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <div style="font-size:13px;opacity:.8;margin-bottom:4px;" id="dashboardDate"></div>
            <h4 class="fw-bold mb-1" style="font-size:1.25rem;">Halo, @userName 👋</h4>
            <p style="font-size:13px;opacity:.85;margin:0;">Pantau audit hygiene Anda hari ini</p>
        </div>
        <a href="@Url.Action("Index", "Audits")" class="btn"
           style="background:rgba(255,255,255,.2);color:#fff;border:1.5px solid rgba(255,255,255,.4);border-radius:12px;font-size:13px;font-weight:600;padding:8px 16px;backdrop-filter:blur(4px);">
            <i class="bx bx-plus me-1"></i> Audit Baru
        </a>
    </div>
</div>

<!-- Stat Chips -->
<div class="row g-2 mb-4">
    <div class="col-6">
        <div class="ha-card ha-stat ha-stat--blue">
            <div class="ha-stat__icon"><i class="bx bx-clipboard"></i></div>
            <div>
                <div class="ha-stat__value text-primary" id="statTotal">—</div>
                <div class="ha-stat__label">Total Audit</div>
            </div>
        </div>
    </div>
    <div class="col-6">
        <div class="ha-card ha-stat ha-stat--green">
            <div class="ha-stat__icon"><i class="bx bx-check-circle"></i></div>
            <div>
                <div class="ha-stat__value text-success" id="statCompleted">—</div>
                <div class="ha-stat__label">Selesai</div>
            </div>
        </div>
    </div>
    <div class="col-6">
        <div class="ha-card ha-stat ha-stat--amber">
            <div class="ha-stat__icon"><i class="bx bx-edit"></i></div>
            <div>
                <div class="ha-stat__value text-warning" id="statDraft">—</div>
                <div class="ha-stat__label">Draft</div>
            </div>
        </div>
    </div>
    <div class="col-6">
        <div class="ha-card ha-stat ha-stat--red">
            <div class="ha-stat__icon"><i class="bx bx-x-circle"></i></div>
            <div>
                <div class="ha-stat__value text-danger" id="statFail">—</div>
                <div class="ha-stat__label">Item Fail</div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Audits -->
<div class="ha-card mb-4">
    <div class="d-flex justify-content-between align-items-center px-4 py-3" style="border-bottom:1px solid var(--ha-border);">
        <span class="fw-bold" style="font-size:15px;">Audit Terbaru</span>
        <a href="@Url.Action("Index", "Audits")" class="ha-badge ha-badge--blue">Lihat Semua →</a>
    </div>
    <div id="recentAuditsList">
        <div class="text-center text-muted py-5">
            <i class="bx bx-loader-circle bx-spin bx-lg d-block mb-2"></i>
            Memuat...
        </div>
    </div>
</div>

@if (isAdmin)
{
    <!-- Admin Quick Links -->
    <div class="mb-2" style="font-size:12px;font-weight:700;color:var(--ha-muted);letter-spacing:.5px;text-transform:uppercase;">Manajemen</div>
    <div class="row g-2">
        <div class="col-4">
            <a href="@Url.Action("Index", "Tenants")" class="ha-card d-flex flex-column align-items-center text-center p-3 text-decoration-none" style="gap:8px;">
                <div class="ha-stat__icon ha-stat--blue" style="width:40px;height:40px;font-size:18px;">
                    <i class="bx bx-store"></i>
                </div>
                <div style="font-size:12px;font-weight:600;color:var(--ha-text);">Tenant</div>
            </a>
        </div>
        <div class="col-4">
            <a href="@Url.Action("Index", "Reports")" class="ha-card d-flex flex-column align-items-center text-center p-3 text-decoration-none" style="gap:8px;">
                <div class="ha-stat__icon ha-stat--amber" style="width:40px;height:40px;font-size:18px;">
                    <i class="bx bx-bar-chart-alt-2"></i>
                </div>
                <div style="font-size:12px;font-weight:600;color:var(--ha-text);">Laporan</div>
            </a>
        </div>
        <div class="col-4">
            <a href="@Url.Action("Index", "Templates")" class="ha-card d-flex flex-column align-items-center text-center p-3 text-decoration-none" style="gap:8px;">
                <div class="ha-stat__icon ha-stat--green" style="width:40px;height:40px;font-size:18px;">
                    <i class="bx bx-list-check"></i>
                </div>
                <div style="font-size:12px;font-weight:600;color:var(--ha-text);">Template</div>
            </a>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('dashboardDate').textContent =
            new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

        function escHtml(str) {
            return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        $.getJSON('/api/audits').done(function (audits) {
            var total     = audits.length;
            var completed = audits.filter(function (a) { return a.status === 'COMPLETED'; }).length;
            var draft     = audits.filter(function (a) { return a.status === 'DRAFT'; }).length;
            var failItems = audits.reduce(function (n, a) {
                return n + (a.items || []).filter(function (i) { return i.status === 'FAIL'; }).length;
            }, 0);

            document.getElementById('statTotal').textContent     = total;
            document.getElementById('statCompleted').textContent = completed;
            document.getElementById('statDraft').textContent     = draft;
            document.getElementById('statFail').textContent      = failItems;

            var recent = audits.slice().sort(function (a, b) { return new Date(b.date) - new Date(a.date); }).slice(0, 5);
            var container = document.getElementById('recentAuditsList');

            if (recent.length === 0) {
                container.innerHTML = '<div class="text-center text-muted py-5"><i class="bx bx-clipboard bx-lg d-block mb-2"></i>Belum ada audit.</div>';
                return;
            }

            var html = '';
            recent.forEach(function (a) {
                var items    = a.items || [];
                var pass     = items.filter(function (i) { return i.status === 'PASS'; }).length;
                var rate     = items.length > 0 ? Math.round(pass / items.length * 100) : 0;
                var barColor = rate >= 70 ? '#22c55e' : '#ef4444';
                var sideColor = a.status === 'COMPLETED' ? '#22c55e' : '#f59e0b';
                var statusClass = a.status === 'COMPLETED' ? 'ha-badge--green' : 'ha-badge--amber';
                var date = new Date(a.date).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' });

                html += '<a href="/Audits/Detail/' + parseInt(a.id, 10) + '" class="ha-audit-item">' +
                    '<div class="ha-audit-item__bar" style="background:' + sideColor + ';"></div>' +
                    '<div style="flex:1;min-width:0;">' +
                        '<div class="d-flex justify-content-between align-items-center gap-2 mb-1">' +
                            '<span class="ha-audit-item__name text-truncate" style="max-width:160px;">' + escHtml(a.tenantName) + '</span>' +
                            '<span class="ha-badge ' + statusClass + ' flex-shrink-0">' + escHtml(a.status) + '</span>' +
                        '</div>' +
                        '<div class="ha-audit-item__meta">' +
                            '<i class="bx bx-calendar-alt me-1"></i>' + date +
                            ' &bull; <i class="bx bx-user me-1"></i>' + escHtml(a.picName) +
                        '</div>' +
                        '<div class="d-flex align-items-center gap-2">' +
                            '<div class="progress flex-grow-1" style="height:5px;border-radius:4px;background:#ebebf0;">' +
                                '<div style="width:' + rate + '%;height:100%;background:' + barColor + ';border-radius:4px;"></div>' +
                            '</div>' +
                            '<span class="ha-audit-item__rate" style="color:' + barColor + ';">' + rate + '%</span>' +
                        '</div>' +
                    '</div>' +
                    '<i class="bx bx-chevron-right" style="color:#c0c4cc;font-size:20px;flex-shrink:0;"></i>' +
                '</a>';
            });

            container.innerHTML = html;
        }).fail(function () {
            ['statTotal','statCompleted','statDraft','statFail'].forEach(function (id) {
                document.getElementById(id).textContent = '0';
            });
            document.getElementById('recentAuditsList').innerHTML =
                '<div class="text-center text-muted py-4"><i class="bx bx-error-circle me-1"></i>Gagal memuat data.</div>';
            showToast('Gagal memuat data dashboard.', 'error');
        });
    </script>
}
