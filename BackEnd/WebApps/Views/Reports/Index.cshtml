@{
    ViewBag.Title = "Laporan";
}

<div id="reports-page">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Laporan Audit</h4>
            <p class="text-muted mb-0">Ringkasan hasil audit hygiene</p>
        </div>
        <a class="btn btn-success" data-bind="attr: { href: exportUrl }">
            <i class="bx bx-download me-1"></i> Export CSV
        </a>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select class="form-select" data-bind="value: filter.status, event: { change: loadReport }">
                        <option value="all">Semua</option>
                        <option value="Completed">Completed</option>
                        <option value="Draft">Draft</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipe</label>
                    <select class="form-select" data-bind="value: filter.type, event: { change: loadReport }">
                        <option value="all">Semua</option>
                        <option value="gas">Dengan Gas</option>
                        <option value="nogas">Tanpa Gas</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Cari Tenant</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bx bx-search"></i></span>
                        <input type="text" class="form-control" placeholder="Nama tenant..." data-bind="value: filter.search, valueUpdate: 'input', event: { input: loadReport }" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4" data-bind="with: summary">
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="avatar flex-shrink-0">
                        <span class="avatar-initial rounded-circle bg-label-primary"><i class="bx bx-store"></i></span>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold" data-bind="text: tenantCount"></h4>
                        <small class="text-muted">Tenant</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="avatar flex-shrink-0">
                        <span class="avatar-initial rounded-circle bg-label-info"><i class="bx bx-list-check"></i></span>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold" data-bind="text: totalItems"></h4>
                        <small class="text-muted">Total Item</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="avatar flex-shrink-0">
                        <span class="avatar-initial rounded-circle bg-label-success"><i class="bx bx-check-circle"></i></span>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold" data-bind="text: totalPass"></h4>
                        <small class="text-muted">Pass</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-3">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="avatar flex-shrink-0">
                        <span class="avatar-initial rounded-circle bg-label-warning"><i class="bx bx-trending-up"></i></span>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold" data-bind="text: (averagePassRate * 100).toFixed(1) + '%'"></h4>
                        <small class="text-muted">Rata-rata Pass</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Report Table -->
    <div class="card">
        <div class="card-header"><h5 class="card-title mb-0">Detail Laporan</h5></div>
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Tenant</th>
                        <th>Tanggal</th>
                        <th>PIC</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Pass/Total</th>
                        <th>Pass Rate</th>
                        <th>Catatan Fail</th>
                    </tr>
                </thead>
                <tbody data-bind="foreach: rows">
                    <tr>
                        <td class="text-muted" data-bind="text: no"></td>
                        <td><span class="fw-semibold" data-bind="text: tenantName"></span></td>
                        <td data-bind="text: new Date(date).toLocaleDateString('id-ID')"></td>
                        <td data-bind="text: picName"></td>
                        <td class="text-center">
                            <span class="badge" data-bind="text: status, css: { 'bg-label-success': status === 'Completed', 'bg-label-warning': status === 'Draft' }"></span>
                        </td>
                        <td class="text-center" data-bind="text: passItems + '/' + totalItems"></td>
                        <td style="min-width:110px;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height:6px;">
                                    <div class="progress-bar bg-success" data-bind="style: { width: (passRate * 100).toFixed(0) + '%' }"></div>
                                </div>
                                <small data-bind="text: (passRate * 100).toFixed(1) + '%'"></small>
                            </div>
                        </td>
                        <td class="text-muted small" data-bind="text: failNotes || '-'" style="max-width:200px;white-space:normal;"></td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div data-bind="visible: rows().length === 0" class="text-center text-muted py-5">
            <i class="bx bx-bar-chart-alt-2 bx-lg d-block mb-2"></i>
            Tidak ada data laporan.
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/reports.viewmodel.js"></script>
    <script>ko.applyBindings(new ReportsViewModel(), document.getElementById('reports-page'));</script>
}
