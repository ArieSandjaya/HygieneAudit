@{
    ViewBag.Title = "Kelola Pengguna";
}

<div id="users-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Kelola Pengguna</h2>
        <button class="btn btn-dark" data-bind="click: showAddForm">+ Tambah Pengguna</button>
    </div>

    <!-- Add/Edit Form -->
    <div class="card mb-4" data-bind="visible: showForm">
        <div class="card-body">
            <h5 class="card-title" data-bind="text: editingId() ? 'Edit Pengguna' : 'Tambah Pengguna'"></h5>
            <div class="row">
                <div class="col-md-3 mb-3" data-bind="visible: !editingId()">
                    <label>Username</label>
                    <input type="text" class="form-control" data-bind="value: form.username" autocomplete="off" />
                </div>
                <div class="col-md-3 mb-3">
                    <label>Nama Lengkap</label>
                    <input type="text" class="form-control" data-bind="value: form.name" />
                </div>
                <div class="col-md-3 mb-3">
                    <label>Password <span data-bind="visible: editingId()" class="text-muted">(kosongkan jika tidak diubah)</span></label>
                    <input type="password" class="form-control" data-bind="value: form.password" autocomplete="new-password" />
                </div>
                <div class="col-md-3 mb-3">
                    <label>Role</label>
                    <select class="form-select" data-bind="value: form.role">
                        <option value="Auditor">Auditor</option>
                        <option value="Admin">Admin</option>
                        <option value="SuperAdmin">Super Admin</option>
                    </select>
                </div>
            </div>
            <button class="btn btn-dark me-2" data-bind="click: saveUser">Simpan</button>
            <button class="btn btn-outline-secondary" data-bind="click: cancelForm">Batal</button>
        </div>
    </div>

    <!-- Users Table -->
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Nama</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: users">
                <tr data-bind="css: { 'text-muted': !isActive }">
                    <td data-bind="text: username"></td>
                    <td data-bind="text: name"></td>
                    <td data-bind="text: role"></td>
                    <td>
                        <span class="badge" data-bind="text: isActive ? 'Aktif' : 'Nonaktif', css: { 'bg-success': isActive, 'bg-secondary': !isActive }"></span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-dark me-1" data-bind="click: $root.editUser">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" data-bind="click: $root.deleteUser, visible: isActive">Nonaktifkan</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/users.viewmodel.js"></script>
    <script>
        ko.applyBindings(new UsersViewModel(), document.getElementById('users-page'));
    </script>
}
