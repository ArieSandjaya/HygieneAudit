@{
    ViewBag.Title = "Pengguna";
}

<div id="users-page">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Pengguna</h4>
            <p class="text-muted mb-0">Kelola akun pengguna sistem</p>
        </div>
        <button class="btn btn-primary" data-bind="click: showAddForm">
            <i class="bx bx-user-plus me-1"></i> Tambah Pengguna
        </button>
    </div>

    <!-- Add/Edit Form -->
    <div class="card mb-4" data-bind="visible: showForm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0" data-bind="text: editingId() ? 'Edit Pengguna' : 'Tambah Pengguna'"></h5>
            <button type="button" class="btn-close" data-bind="click: cancelForm"></button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Nama Lengkap</label>
                    <input type="text" class="form-control" data-bind="value: form.name" placeholder="Nama lengkap" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Username</label>
                    <input type="text" class="form-control" data-bind="value: form.username" placeholder="Username login" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Role</label>
                    <select class="form-select" data-bind="value: form.role">
                        <option value="Auditor">Auditor</option>
                        <option value="Admin">Admin</option>
                        <option value="SuperAdmin">SuperAdmin</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label" data-bind="text: editingId() ? 'Password Baru (kosongkan jika tidak diubah)' : 'Password'"></label>
                    <input type="password" class="form-control" data-bind="value: form.password" placeholder="••••••••" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary me-2" data-bind="click: saveUser"><i class="bx bx-check me-1"></i> Simpan</button>
                <button class="btn btn-outline-secondary" data-bind="click: cancelForm">Batal</button>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card">
        <div class="card-header"><h5 class="card-title mb-0">Daftar Pengguna</h5></div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Pengguna</th>
                        <th>Username</th>
                        <th class="text-center">Role</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody data-bind="foreach: users">
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar avatar-sm">
                                    <span class="avatar-initial rounded-circle bg-label-primary" data-bind="text: (name() || '?').charAt(0).toUpperCase()"></span>
                                </div>
                                <span class="fw-semibold" data-bind="text: name"></span>
                            </div>
                        </td>
                        <td class="text-muted" data-bind="text: username"></td>
                        <td class="text-center">
                            <span class="badge" data-bind="text: role, css: { 'bg-label-danger': role === 'SuperAdmin', 'bg-label-warning': role === 'Admin', 'bg-label-primary': role === 'Auditor' }"></span>
                        </td>
                        <td class="text-center">
                            <span class="badge" data-bind="text: isActive ? 'Aktif' : 'Nonaktif', css: { 'bg-label-success': isActive, 'bg-label-secondary': !isActive }"></span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-icon btn-outline-primary me-1" data-bind="click: $root.editUser" title="Edit">
                                <i class="bx bx-edit-alt"></i>
                            </button>
                            <button class="btn btn-sm btn-icon btn-outline-danger" data-bind="click: $root.deleteUser" title="Hapus">
                                <i class="bx bx-trash"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div data-bind="visible: users().length === 0" class="text-center text-muted py-5">
            <i class="bx bx-group bx-lg d-block mb-2"></i>
            Belum ada pengguna.
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/users.viewmodel.js"></script>
    <script>ko.applyBindings(new UsersViewModel(), document.getElementById('users-page'));</script>
}
