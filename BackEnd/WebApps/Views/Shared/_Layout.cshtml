@using System.Security.Claims
@{
    var userName = (User.Identity as ClaimsIdentity)?.FindFirst(ClaimTypes.GivenName)?.Value ?? User.Identity?.Name ?? "User";
    var userRole = (User.Identity as ClaimsIdentity)?.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var isAdmin = userRole == "Admin" || userRole == "SuperAdmin";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="id" class="light-style layout-menu-fixed" dir="ltr"
      data-theme="theme-default"
      data-assets-path="@Url.Content("~/Content/sneat/")"
      data-template="vertical-menu-template-free">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Title != null ? ViewBag.Title + " | " : "")Hygiene Audit</title>
    <meta name="description" content="Aplikasi Audit Hygiene" />
    <meta name="theme-color" content="#696cff" />

    <!-- PWA -->
    <link rel="manifest" href="@Url.Content("~/manifest.json")" />
    <link rel="apple-touch-icon" href="@Url.Content("~/Content/sneat/img/favicon/favicon.ico")" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="@Url.Content("~/Content/sneat/img/favicon/favicon.ico")" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin" />
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet" />

    <!-- Boxicons -->
    <link rel="stylesheet" href="@Url.Content("~/Content/sneat/vendor/fonts/boxicons.css")" />

    <!-- Core CSS -->
    <link rel="stylesheet" href="@Url.Content("~/Content/sneat/vendor/css/core.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/sneat/vendor/css/theme-default.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/sneat/css/demo.css")" />
    <link rel="stylesheet" href="@Url.Content("~/Content/sneat/vendor/libs/perfect-scrollbar/perfect-scrollbar.css")" />

    <!-- Helpers must load before config -->
    <script src="@Url.Content("~/Content/sneat/vendor/js/helpers.js")"></script>
    <script src="@Url.Content("~/Content/sneat/js/config.js")"></script>
</head>

<body>
@if (Request.IsAuthenticated)
{
    <div class="layout-wrapper layout-content-navbar">
        <div class="layout-container">

            <!-- Sidebar -->
            <aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
                <div class="app-brand demo">
                    <a href="@Url.Action("Index", "Home")" class="app-brand-link">
                        <span class="app-brand-logo demo">
                            <svg width="25" viewBox="0 0 25 42" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
                                <defs>
                                    <path d="M13.7918663,0.358365126 L3.39788168,7.44174259 C0.566865006,9.69408886 -0.379795268,12.4788597 0.557900856,15.7960551 C0.68998853,16.2305145 1.09562888,17.7872135 3.12357076,19.2293357 C3.8146334,19.7207684 5.32369333,20.3834223 7.65075054,21.2172976 L7.59773219,21.2525164 L2.63468769,24.5493413 C0.445452254,26.3002124 0.0884951797,28.5083815 1.56381646,31.1738486 C2.83770406,32.8170431 5.20850219,33.2640127 7.09180128,32.5391577 C8.347334,32.0559211 11.4559176,30.0011079 16.4175519,26.3747182 C18.0338572,24.4997857 18.6973423,22.4544883 18.4080071,20.2388261 C17.963753,17.5346866 16.1776345,15.5799961 13.0496516,14.3747546 L10.9194936,13.4715819 L18.6192054,7.984237 L13.7918663,0.358365126 Z" id="p1"></path>
                                    <path d="M5.47320593,6.00457225 C4.05321814,8.216144 4.36334763,10.0722806 6.40359441,11.5729822 C8.61520715,12.571656 10.0999176,13.2171421 10.8577257,13.5094407 L15.5088241,14.433041 L18.6192054,7.984237 C15.5364148,3.11535317 13.9273018,0.573395879 13.7918663,0.358365126 C13.5790555,0.511491653 10.8061687,2.3935607 5.47320593,6.00457225 Z" id="p3"></path>
                                    <path d="M7.50063644,21.2294429 L12.3234468,23.3159332 C14.1688022,24.7579751 14.397098,26.4880487 13.008334,28.506154 C11.6195701,30.5242593 10.3099883,31.790241 9.07958868,32.3040991 C5.78142938,33.4346997 4.13234973,34 4.13234973,34 C4.13234973,34 2.75489982,33.0538207 0,31.1614621 C-0.55822714,27.8186216 -0.55822714,26.0572515 0,25.8773518 C0.83734071,25.6075023 2.77988457,22.8248993 3.3049379,22.52991 C3.65497346,22.3332504 5.05353963,21.8997614 7.50063644,21.2294429 Z" id="p4"></path>
                                    <path d="M20.6,7.13333333 L25.6,13.8 C26.2627417,14.6836556 26.0836556,15.9372583 25.2,16.6 C24.8538077,16.8596443 24.4327404,17 24,17 L14,17 C12.8954305,17 12,16.1045695 12,15 C12,14.5672596 12.1403557,14.1461923 12.4,13.8 L17.4,7.13333333 C18.0627417,6.24967773 19.3163444,6.07059163 20.2,6.73333333 C20.3516113,6.84704183 20.4862915,6.981722 20.6,7.13333333 Z" id="p5"></path>
                                </defs>
                                <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                    <g transform="translate(-27,-15)">
                                        <g transform="translate(27,15)">
                                            <g transform="translate(0,8)">
                                                <mask id="m2" fill="white"><use xlink:href="#p1"></use></mask>
                                                <use fill="#696cff" xlink:href="#p1"></use>
                                                <g mask="url(#m2)"><use fill="#696cff" xlink:href="#p3"></use><use fill-opacity="0.2" fill="#FFFFFF" xlink:href="#p3"></use></g>
                                                <g mask="url(#m2)"><use fill="#696cff" xlink:href="#p4"></use><use fill-opacity="0.2" fill="#FFFFFF" xlink:href="#p4"></use></g>
                                            </g>
                                            <g transform="translate(19,11) rotate(-300) translate(-19,-11)">
                                                <use fill="#696cff" xlink:href="#p5"></use>
                                                <use fill-opacity="0.2" fill="#FFFFFF" xlink:href="#p5"></use>
                                            </g>
                                        </g>
                                    </g>
                                </g>
                            </svg>
                        </span>
                        <span class="app-brand-text demo menu-text fw-bolder ms-2">HygieneAudit</span>
                    </a>
                    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto d-block d-xl-none">
                        <i class="bx bx-chevron-left bx-sm align-middle"></i>
                    </a>
                </div>
                <div class="menu-inner-shadow"></div>
                <ul class="menu-inner py-1">
                    <li class="menu-item @(currentController == "Home" ? "active" : "")">
                        <a href="@Url.Action("Index", "Home")" class="menu-link">
                            <i class="menu-icon tf-icons bx bx-home-circle"></i>
                            <div>Dashboard</div>
                        </a>
                    </li>
                    <li class="menu-header small text-uppercase"><span class="menu-header-text">Operasional</span></li>
                    <li class="menu-item @(currentController == "Audits" ? "active" : "")">
                        <a href="@Url.Action("Index", "Audits")" class="menu-link">
                            <i class="menu-icon tf-icons bx bx-clipboard"></i>
                            <div>Audit</div>
                        </a>
                    </li>
                    <li class="menu-item @(currentController == "Tenants" ? "active" : "")">
                        <a href="@Url.Action("Index", "Tenants")" class="menu-link">
                            <i class="menu-icon tf-icons bx bx-store"></i>
                            <div>Tenant</div>
                        </a>
                    </li>
                    @if (isAdmin)
                    {
                        <li class="menu-header small text-uppercase"><span class="menu-header-text">Manajemen</span></li>
                        <li class="menu-item @(currentController == "Templates" ? "active" : "")">
                            <a href="@Url.Action("Index", "Templates")" class="menu-link">
                                <i class="menu-icon tf-icons bx bx-list-check"></i>
                                <div>Template</div>
                            </a>
                        </li>
                        <li class="menu-item @(currentController == "Users" ? "active" : "")">
                            <a href="@Url.Action("Index", "Users")" class="menu-link">
                                <i class="menu-icon tf-icons bx bx-group"></i>
                                <div>Pengguna</div>
                            </a>
                        </li>
                        <li class="menu-item @(currentController == "Reports" ? "active" : "")">
                            <a href="@Url.Action("Index", "Reports")" class="menu-link">
                                <i class="menu-icon tf-icons bx bx-bar-chart-alt-2"></i>
                                <div>Laporan</div>
                            </a>
                        </li>
                    }
                </ul>
            </aside>
            <!-- End Sidebar -->

            <div class="layout-page">
                <!-- Topbar -->
                <nav class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme" id="layout-navbar">
                    <div class="layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
                        <a class="nav-item nav-link px-0 me-xl-4" href="javascript:void(0)">
                            <i class="bx bx-menu bx-sm"></i>
                        </a>
                    </div>
                    <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
                        <ul class="navbar-nav flex-row align-items-center ms-auto">
                            <li class="nav-item navbar-dropdown dropdown-user dropdown">
                                <a class="nav-link dropdown-toggle hide-arrow" href="javascript:void(0);" data-bs-toggle="dropdown">
                                    <div class="avatar avatar-online">
                                        <span class="avatar-initial rounded-circle bg-label-primary">@(userName.Length > 0 ? userName[0].ToString().ToUpper() : "U")</span>
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <div class="d-flex">
                                                <div class="flex-shrink-0 me-3">
                                                    <div class="avatar">
                                                        <span class="avatar-initial rounded-circle bg-label-primary">@(userName.Length > 0 ? userName[0].ToString().ToUpper() : "U")</span>
                                                    </div>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <span class="fw-semibold d-block">@userName</span>
                                                    <small class="text-muted">@userRole</small>
                                                </div>
                                            </div>
                                        </a>
                                    </li>
                                    <li><div class="dropdown-divider"></div></li>
                                    <li>
                                        @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "topbarLogoutForm" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <a class="dropdown-item" href="javascript:document.getElementById('topbarLogoutForm').submit();">
                                                <i class="bx bx-power-off me-2"></i>
                                                <span>Keluar</span>
                                            </a>
                                        }
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </nav>
                <!-- End Topbar -->

                <div class="content-wrapper">
                    <div class="container-xxl flex-grow-1 container-p-y">
                        @RenderBody()
                    </div>
                    <footer class="content-footer footer bg-footer-theme">
                        <div class="container-xxl d-flex flex-wrap justify-content-between py-2 flex-md-row flex-column">
                            <div class="mb-2 mb-md-0">
                                <span class="footer-text fw-bolder">HygieneAudit</span> &copy; @DateTime.Now.Year
                            </div>
                        </div>
                    </footer>
                    <div class="content-backdrop fade"></div>
                </div>
            </div>
        </div>
        <div class="layout-overlay layout-menu-toggle"></div>
    </div>
}
else
{
    @RenderBody()
}

<!-- Vendor JS -->
<script src="@Url.Content("~/Content/sneat/vendor/libs/jquery/jquery.js")"></script>
<script src="@Url.Content("~/Content/sneat/vendor/libs/popper/popper.js")"></script>
<script src="@Url.Content("~/Content/sneat/vendor/js/bootstrap.js")"></script>
<script src="@Url.Content("~/Content/sneat/vendor/libs/perfect-scrollbar/perfect-scrollbar.js")"></script>
<script src="@Url.Content("~/Content/sneat/vendor/js/menu.js")"></script>
<script src="@Url.Content("~/Content/sneat/js/main.js")"></script>

@RenderSection("Scripts", required: false)

<div id="ha-toast-container" style="position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;width:min(90vw,340px);text-align:center;"></div>
<style>
    @@keyframes haToastIn { from { opacity:0;transform:translateY(-16px); } to { opacity:1;transform:translateY(0); } }
</style>
<script>
window.showToast = function(msg, type) {
    var colors = { success:'#22c55e', error:'#ef4444', info:'#696cff', warning:'#f59e0b' };
    var bg = colors[type || 'success'] || colors.success;
    var el = document.createElement('div');
    el.style.cssText = 'background:'+bg+';color:#fff;padding:12px 24px;border-radius:12px;font-weight:600;font-size:14px;box-shadow:0 4px 12px rgba(0,0,0,.18);pointer-events:auto;animation:haToastIn .25s ease;';
    el.textContent = msg;
    var c = document.getElementById('ha-toast-container');
    c.appendChild(el);
    setTimeout(function(){ if(el.parentNode) el.parentNode.removeChild(el); }, 3000);
};
</script>

<script>
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
            navigator.serviceWorker.register('/service-worker.js')
                .then(function (reg) { console.log('SW registered:', reg.scope); })
                .catch(function (err) { console.log('SW registration failed:', err); });
        });
    }
</script>
</body>
</html>
