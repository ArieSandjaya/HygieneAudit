@using System.Security.Claims
@{
    var userName = (User.Identity as ClaimsIdentity)?.FindFirst(ClaimTypes.GivenName)?.Value ?? User.Identity?.Name ?? "User";
    var userRole = (User.Identity as ClaimsIdentity)?.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var isAdmin = userRole == "Admin" || userRole == "SuperAdmin";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="id" class="light-style layout-menu-fixed" dir="ltr"
      data-theme="theme-default"
      data-assets-path="@Url.Content("~/Content/sneat/")"
      data-template="vertical-menu-template-free">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
