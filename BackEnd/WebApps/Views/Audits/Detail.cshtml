@{
    ViewBag.Title = "Detail Audit";
}

<div id="audit-detail-page">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h4 class="fw-bold mb-1" data-bind="text: 'Audit: ' + tenantName()"></h4>
            <p class="text-muted mb-0">
                <span data-bind="text: auditDate() ? new Date(auditDate()).toLocaleDateString('id-ID') : ''"></span>
                &nbsp;&bull;&nbsp;
                <span data-bind="text: picName()"></span>
                &nbsp;&bull;&nbsp;
                <span class="badge bg-label-info" data-bind="text: isGas() ? 'Dengan Gas' : 'Tanpa Gas'"></span>
                &nbsp;
                <span class="badge" data-bind="text: status(), css: { 'bg-label-success': status() === 'COMPLETED', 'bg-label-warning': status() === 'DRAFT' }"></span>
            </p>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <a href="@Url.Action("Index", "Audits")" class="btn btn-outline-secondary">
                <i class="bx bx-arrow-back me-1"></i> Kembali
            </a>
            <button class="btn btn-warning" data-bind="click: saveDraft, visible: status() !== 'COMPLETED'">
                <i class="bx bx-save me-1"></i> Simpan Draft
            </button>
            <button class="btn btn-success" data-bind="click: submitAudit, visible: status() !== 'COMPLETED'">
                <i class="bx bx-check-circle me-1"></i> Submit
            </button>
        </div>
    </div>

    <!-- Progress Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body py-3">
                    <h3 class="text-primary mb-0" data-bind="text: totalCount"></h3>
                    <small class="text-muted">Total Item</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body py-3">
                    <h3 class="text-success mb-0" data-bind="text: passCount"></h3>
                    <small class="text-muted">Pass</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body py-3">
                    <h3 class="text-danger mb-0" data-bind="text: failCount"></h3>
                    <small class="text-muted">Fail</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Checklist by Category -->
    <div data-bind="foreach: categories">
        <div class="card mb-3">
            <!-- Collapsible category header -->
            <div class="card-header d-flex justify-content-between align-items-center"
                 style="cursor:pointer;" data-bind="click: $root.toggleCategory">
                <h6 class="card-title mb-0 text-uppercase fw-semibold" data-bind="text: name"></h6>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-label-secondary" data-bind="text: checkedCount() + '/' + items.length"></span>
                    <i class="bx" data-bind="css: { 'bx-chevron-up': !collapsed(), 'bx-chevron-down': collapsed() }"></i>
                </div>
            </div>
            <div data-bind="visible: !collapsed()">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Item</th>
                                <th style="width:120px;" class="text-center">Status</th>
                                <th style="width:180px;">Foto</th>
                            </tr>
                        </thead>
                        <tbody data-bind="foreach: items">
                            <tr data-bind="css: { 'table-success': status() === 'PASS', 'table-danger': status() === 'FAIL' }">
                                <!-- Item + Catatan selalu tampil -->
                                <td class="align-middle">
                                    <div data-bind="text: name"></div>
                                    <div class="mt-2">
                                        <small class="text-muted">Catatan
                                            <span class="text-danger" data-bind="visible: status() === 'FAIL'">*</span>
                                        </small>
                                        <textarea rows="2" class="form-control form-control-sm mt-1"
                                                  style="resize:vertical;min-height:54px;"
                                                  placeholder="Tambahkan catatan..."
                                                  data-bind="value: note, valueUpdate: 'afterkeydown',
                                                             css: { 'is-invalid': status() === 'FAIL' && !note().trim() },
                                                             event: { change: $root.onItemChange.bind($root, $data) }"></textarea>
                                    </div>
                                </td>
                                <!-- Circular Pass/Fail emoji buttons -->
                                <td class="text-center align-middle">
                                    <div class="d-flex justify-content-center gap-2">
                                        <button type="button"
                                                style="width:44px;height:44px;border-radius:50%;border:3px solid;font-size:22px;cursor:pointer;transition:.15s;line-height:1;padding:0;"
                                                data-bind="click: function(){ $root.setItemStatus($data, 'PASS') },
                                                           style: { borderColor: status() === 'PASS' ? '#22c55e' : '#d1d5db',
                                                                    background: status() === 'PASS' ? '#dcfce7' : 'white' }">
                                            &#128522;
                                        </button>
                                        <button type="button"
                                                style="width:44px;height:44px;border-radius:50%;border:3px solid;font-size:22px;cursor:pointer;transition:.15s;line-height:1;padding:0;"
                                                data-bind="click: function(){ $root.setItemStatus($data, 'FAIL') },
                                                           style: { borderColor: status() === 'FAIL' ? '#ef4444' : '#d1d5db',
                                                                    background: status() === 'FAIL' ? '#fee2e2' : 'white' }">
                                            &#128545;
                                        </button>
                                    </div>
                                </td>
                                <!-- Foto: Kamera & Galeri terpisah -->
                                <td class="align-middle">
                                    <div data-bind="visible: $root.status() !== 'COMPLETED'">
                                        <div class="d-flex gap-2 mb-2">
                                            <label class="text-center p-2 flex-fill"
                                                   style="border:2px dashed #d1d5db;border-radius:10px;cursor:pointer;">
                                                <div style="font-size:18px;line-height:1.4;">&#128247;</div>
                                                <div style="font-size:11px;color:#6b7280;">Kamera</div>
                                                <input type="file" accept="image/*" capture="environment" class="d-none"
                                                       data-bind="event: { change: function(d,e){ $root.addPhoto($data, e) } }" />
                                            </label>
                                            <label class="text-center p-2 flex-fill"
                                                   style="border:2px dashed #d1d5db;border-radius:10px;cursor:pointer;">
                                                <div style="font-size:18px;line-height:1.4;">&#128444;&#65039;</div>
                                                <div style="font-size:11px;color:#6b7280;">Galeri</div>
                                                <input type="file" accept="image/*" multiple class="d-none"
                                                       data-bind="event: { change: function(d,e){ $root.addPhoto($data, e) } }" />
                                            </label>
                                        </div>
                                    </div>
                                    <div class="d-flex flex-wrap gap-1">
                                        <!-- ko foreach: photos -->
                                        <div class="position-relative flex-shrink-0" style="width:48px;height:48px;">
                                            <img data-bind="attr: { src: $data }"
                                                 style="width:48px;height:48px;object-fit:cover;border-radius:6px;" />
                                            <!-- ko if: $root.status() !== 'COMPLETED' -->
                                            <button type="button" class="btn btn-danger position-absolute top-0 end-0 p-0"
                                                    style="width:16px;height:16px;font-size:9px;border-radius:50%;min-width:0;line-height:1;"
                                                    data-bind="click: function(){ $root.removePhoto($parent, $data) }">
                                                &times;
                                            </button>
                                            <!-- /ko -->
                                        </div>
                                        <!-- /ko -->
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Empty state -->
    <div data-bind="visible: categories().length === 0" class="text-center text-muted py-5">
        <i class="bx bx-loader-circle bx-spin bx-lg d-block mb-2"></i>
        Memuat data audit...
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/audits.viewmodel.js"></script>
    <script>
        var auditId = '@Html.Raw(ViewBag.AuditId)';
        ko.applyBindings(new AuditDetailViewModel(auditId), document.getElementById('audit-detail-page'));
    </script>
}
