@{
    ViewBag.Title = "Detail Audit";
}

<div id="audit-detail-page">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1" data-bind="text: 'Audit: ' + tenantName()"></h4>
            <p class="text-muted mb-0">
                <span data-bind="text: new Date(auditDate()).toLocaleDateString('id-ID')"></span>
                &nbsp;&bull;&nbsp;
                <span class="badge" data-bind="text: status, css: { 'bg-label-success': status() === 'Completed', 'bg-label-warning': status() === 'Draft' }"></span>
            </p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index", "Audits")" class="btn btn-outline-secondary">
                <i class="bx bx-arrow-back me-1"></i> Kembali
            </a>
            <button class="btn btn-warning" data-bind="click: saveDraft, visible: status() !== 'Completed'">
                <i class="bx bx-save me-1"></i> Simpan Draft
            </button>
            <button class="btn btn-success" data-bind="click: submitAudit, visible: status() !== 'Completed'">
                <i class="bx bx-check-circle me-1"></i> Submit
            </button>
        </div>
    </div>

    <!-- Progress Card -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-primary mb-0" data-bind="text: totalItems"></h3>
                    <small class="text-muted">Total Item</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-success mb-0" data-bind="text: passCount"></h3>
                    <small class="text-muted">Pass</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-danger mb-0" data-bind="text: failCount"></h3>
                    <small class="text-muted">Fail</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Checklist by Category -->
    <div data-bind="foreach: categories">
        <div class="card mb-3">
            <div class="card-header">
                <h6 class="card-title mb-0 text-uppercase fw-semibold" data-bind="text: name"></h6>
            </div>
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Item</th>
                            <th style="width:120px;" class="text-center">Status</th>
                            <th>Catatan</th>
                        </tr>
                    </thead>
                    <tbody data-bind="foreach: items">
                        <tr>
                            <td>
                                <span data-bind="text: templateName"></span>
                                <span class="badge bg-label-info ms-1" data-bind="visible: requiresGas">Gas</span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button" class="btn" data-bind="click: function(){ $root.setItemResult($data, true); }, css: { 'btn-success': result() === true, 'btn-outline-success': result() !== true }">Pass</button>
                                    <button type="button" class="btn" data-bind="click: function(){ $root.setItemResult($data, false); }, css: { 'btn-danger': result() === false, 'btn-outline-danger': result() !== false }">Fail</button>
                                </div>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm" placeholder="Catatan..." data-bind="value: notes, visible: result() === false" />
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/audits.viewmodel.js"></script>
    <script>
        var auditId = @Html.Raw(ViewBag.AuditId ?? "null");
        ko.applyBindings(new AuditDetailViewModel(auditId), document.getElementById('audit-detail-page'));
    </script>
}
