@{
    ViewBag.Title = "Audit";
}

<div id="audits-page">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Daftar Audit</h4>
            <p class="text-muted mb-0">Kelola sesi audit hygiene</p>
        </div>
        <button class="btn btn-primary" data-bind="click: showCreateForm">
            <i class="bx bx-plus me-1"></i> Audit Baru
        </button>
    </div>

    <!-- Create Form -->
    <div class="card mb-4" data-bind="visible: showForm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Buat Audit Baru</h5>
            <button type="button" class="btn-close" data-bind="click: cancelForm"></button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Tenant</label>
                    <select class="form-select" data-bind="value: newAudit.tenantId, options: tenants, optionsText: 'name', optionsValue: 'id', optionsCaption: '-- Pilih Tenant --'"></select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tanggal</label>
                    <input type="date" class="form-control" data-bind="value: newAudit.auditDate" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tipe</label>
                    <select class="form-select" data-bind="value: newAudit.includeGas">
                        <option value="false">Tanpa Gas</option>
                        <option value="true">Dengan Gas</option>
                    </select>
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary me-2" data-bind="click: createAudit"><i class="bx bx-check me-1"></i> Buat</button>
                <button class="btn btn-outline-secondary" data-bind="click: cancelForm">Batal</button>
            </div>
        </div>
    </div>

    <!-- Audit Table -->
    <div class="card">
        <div class="card-header"><h5 class="card-title mb-0">Semua Audit</h5></div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tenant</th>
                        <th>Tanggal</th>
                        <th>PIC</th>
                        <th>Status</th>
                        <th>Pass Rate</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody data-bind="foreach: audits">
                    <tr>
                        <td><span class="fw-semibold" data-bind="text: tenantName"></span></td>
                        <td data-bind="text: new Date(auditDate).toLocaleDateString('id-ID')"></td>
                        <td data-bind="text: picName"></td>
                        <td>
                            <span class="badge" data-bind="text: status, css: { 'bg-label-success': status === 'Completed', 'bg-label-warning': status === 'Draft', 'bg-label-info': status === 'InProgress' }"></span>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height:6px;min-width:60px;">
                                    <div class="progress-bar bg-primary" data-bind="style: { width: (passRate * 100).toFixed(0) + '%' }"></div>
                                </div>
                                <small data-bind="text: (passRate * 100).toFixed(0) + '%'"></small>
                            </div>
                        </td>
                        <td class="text-center">
                            <a data-bind="attr: { href: '/Audits/Detail/' + id }" class="btn btn-sm btn-icon btn-outline-primary">
                                <i class="bx bx-edit-alt"></i>
                            </a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div data-bind="visible: audits().length === 0" class="text-center text-muted py-5">
            <i class="bx bx-clipboard bx-lg d-block mb-2"></i>
            Belum ada data audit.
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/audits.viewmodel.js"></script>
    <script>ko.applyBindings(new AuditsViewModel(), document.getElementById('audits-page'));</script>
}
