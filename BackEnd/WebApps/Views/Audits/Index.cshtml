@{
    ViewBag.Title = "Audit";
}

<div id="audits-page">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Daftar Audit</h4>
            <p class="text-muted mb-0">Kelola sesi audit hygiene</p>
        </div>
        <button class="btn btn-primary" data-bind="click: showCreateForm">
            <i class="bx bx-plus me-1"></i> Audit Baru
        </button>
    </div>

    <!-- Create Form -->
    <div class="card mb-4" data-bind="visible: showForm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Buat Audit Baru</h5>
            <button type="button" class="btn-close" data-bind="click: cancelForm"></button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Tenant</label>
                    <div class="dropdown">
                        <button type="button" class="btn btn-outline-secondary dropdown-toggle w-100 text-start d-flex justify-content-between align-items-center"
                                data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <span data-bind="text: selectedTenantName() || '-- Pilih Tenant --'"></span>
                        </button>
                        <ul class="dropdown-menu w-100 p-0" style="min-width:100%">
                            <li class="px-2 pt-2 pb-1">
                                <input type="text" class="form-control form-control-sm" placeholder="Cari tenant..."
                                       data-bind="value: tenantSearch, valueUpdate: 'input'" autocomplete="off" />
                            </li>
                            <li><hr class="dropdown-divider m-0"></li>
                            <li style="max-height:220px;overflow-y:auto;">
                                <!-- ko foreach: filteredTenants -->
                                <a class="dropdown-item" href="#"
                                   data-bind="text: name, click: $root.selectTenant, css: { active: id == $root.newAudit.tenantId() }"></a>
                                <!-- /ko -->
                                <!-- ko if: filteredTenants().length === 0 -->
                                <span class="dropdown-item text-muted small">Tidak ada hasil</span>
                                <!-- /ko -->
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tanggal</label>
                    <input type="date" class="form-control" data-bind="value: newAudit.auditDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">PIC (Auditor)</label>
                    <select class="form-select" data-bind="value: newAudit.picId, options: users, optionsText: 'name', optionsValue: 'id', optionsCaption: '-- Pilih PIC --'"></select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tipe</label>
                    <select class="form-select" data-bind="value: newAudit.includeGas">
                        <option value="false">Tanpa Gas</option>
                        <option value="true">Dengan Gas</option>
                    </select>
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary me-2" data-bind="click: createAudit"><i class="bx bx-check me-1"></i> Buat</button>
                <button class="btn btn-outline-secondary" data-bind="click: cancelForm">Batal</button>
            </div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link" href="#" data-bind="click: function(){ activeTab('all') }, css: { active: activeTab() === 'all' }">
                Semua <span class="badge bg-label-secondary ms-1" data-bind="text: audits().length"></span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#" data-bind="click: function(){ activeTab('active') }, css: { active: activeTab() === 'active' }">
                Aktif <span class="badge bg-label-warning ms-1" data-bind="text: audits().filter(function(a){ return a.status !== 'COMPLETED'; }).length"></span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#" data-bind="click: function(){ activeTab('history') }, css: { active: activeTab() === 'history' }">
                History <span class="badge bg-label-success ms-1" data-bind="text: audits().filter(function(a){ return a.status === 'COMPLETED'; }).length"></span>
            </a>
        </li>
    </ul>

    <!-- Audit Table -->
    <div class="card">
        <div class="card-header"><h5 class="card-title mb-0" data-bind="text: activeTab() === 'history' ? 'Riwayat Audit (Completed)' : activeTab() === 'active' ? 'Audit Aktif' : 'Semua Audit'"></h5></div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tenant</th>
                        <th>Tanggal</th>
                        <th>PIC</th>
                        <th class="text-center">Tipe</th>
                        <th class="text-center">Status</th>
                        <th>Pass Rate</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody data-bind="foreach: filteredAudits">
                    <tr>
                        <td><span class="fw-semibold" data-bind="text: tenantName"></span></td>
                        <td data-bind="text: new Date(date).toLocaleDateString('id-ID')"></td>
                        <td data-bind="text: picName"></td>
                        <td class="text-center">
                            <span class="badge" data-bind="text: isGas ? 'Gas' : 'Non-Gas', css: { 'bg-label-info': isGas, 'bg-label-secondary': !isGas }"></span>
                        </td>
                        <td class="text-center">
                            <span class="badge" data-bind="text: status, css: { 'bg-label-success': status === 'COMPLETED', 'bg-label-warning': status === 'DRAFT' }"></span>
                        </td>
                        <td style="min-width:120px;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height:6px;">
                                    <div class="progress-bar bg-success" data-bind="style: { width: (passRate * 100).toFixed(0) + '%' }"></div>
                                </div>
                                <small data-bind="text: (passRate * 100).toFixed(0) + '%'"></small>
                            </div>
                        </td>
                        <td class="text-center">
                            <a data-bind="attr: { href: '/Audits/Detail/' + id }" class="btn btn-sm btn-icon btn-outline-primary" title="Buka">
                                <i class="bx bx-edit-alt"></i>
                            </a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div data-bind="visible: filteredAudits().length === 0" class="text-center text-muted py-5">
            <i class="bx bx-clipboard bx-lg d-block mb-2"></i>
            Belum ada data audit.
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/audits.viewmodel.js"></script>
    <script>ko.applyBindings(new AuditsViewModel(), document.getElementById('audits-page'));</script>
}
