@{
    ViewBag.Title = "Tenant";
}

<div id="tenants-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <div>
            <h4 class="fw-bold mb-1">Tenant</h4>
            <p class="text-muted mb-0">Kelola data tenant</p>
        </div>
        <button class="btn btn-primary" data-bind="click: showAddForm, visible: isAdmin">
            <i class="bx bx-plus me-1"></i> Tambah Tenant
        </button>
    </div>

    <!-- Add/Edit Form -->
    <div class="card mb-4" data-bind="visible: showForm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0" data-bind="text: editingId() ? 'Edit Tenant' : 'Tambah Tenant'"></h5>
            <button type="button" class="btn-close" data-bind="click: cancelForm"></button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nama Tenant</label>
                    <input type="text" class="form-control" data-bind="value: form.name" placeholder="Nama tenant" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Lokasi</label>
                    <input type="text" class="form-control" data-bind="value: form.location" placeholder="Lokasi/blok" />
                </div>
                <div class="col-md-12">
                    <label class="form-label">Deskripsi</label>
                    <input type="text" class="form-control" data-bind="value: form.description" placeholder="Deskripsi singkat (opsional)" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary me-2" data-bind="click: saveTenant"><i class="bx bx-check me-1"></i> Simpan</button>
                <button class="btn btn-outline-secondary" data-bind="click: cancelForm">Batal</button>
            </div>
        </div>
    </div>

    <!-- Tenant Table -->
    <div class="card">
        <div class="card-header"><h5 class="card-title mb-0">Daftar Tenant</h5></div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nama</th>
                        <th>Lokasi</th>
                        <th>Deskripsi</th>
                        <th class="text-center" data-bind="visible: isAdmin">Aksi</th>
                    </tr>
                </thead>
                <tbody data-bind="foreach: tenants">
                    <tr>
                        <td><span class="fw-semibold" data-bind="text: name"></span></td>
                        <td><span class="badge bg-label-secondary" data-bind="text: location || '-'"></span></td>
                        <td class="text-muted" data-bind="text: description || '-'"></td>
                        <td class="text-center" data-bind="visible: $root.isAdmin">
                            <button class="btn btn-sm btn-icon btn-outline-primary me-1" data-bind="click: $root.editTenant" title="Edit">
                                <i class="bx bx-edit-alt"></i>
                            </button>
                            <button class="btn btn-sm btn-icon btn-outline-danger" data-bind="click: $root.deleteTenant" title="Hapus">
                                <i class="bx bx-trash"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div data-bind="visible: tenants().length === 0" class="text-center text-muted py-5">
            <i class="bx bx-store bx-lg d-block mb-2"></i>
            Belum ada data tenant.
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/tenants.viewmodel.js"></script>
    <script>ko.applyBindings(new TenantsViewModel(), document.getElementById('tenants-page'));</script>
}
