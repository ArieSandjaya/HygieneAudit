@{
    ViewBag.Title = "Template";
}

<div id="templates-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
        <div>
            <h4 class="fw-bold mb-1">Template Checklist</h4>
            <p class="text-muted mb-0">Kelola item checklist audit</p>
        </div>
        <button class="btn btn-primary" data-bind="click: showAddForm">
            <i class="bx bx-plus me-1"></i> Tambah Item
        </button>
    </div>

    <!-- Add/Edit Form -->
    <div class="card mb-4" data-bind="visible: showForm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0" data-bind="text: editingId() ? 'Edit Template' : 'Tambah Template'"></h5>
            <button type="button" class="btn-close" data-bind="click: cancelForm"></button>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Kategori</label>
                    <input type="text" class="form-control" data-bind="value: form.category" placeholder="Contoh: Kebersihan Umum" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Nama Item</label>
                    <input type="text" class="form-control" data-bind="value: form.name" placeholder="Nama item checklist" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Urutan</label>
                    <input type="number" class="form-control" data-bind="value: form.displayOrder" min="1" />
                </div>
                <div class="col-md-2 d-flex align-items-end pb-1">
                    <div class="form-check form-switch">
                        <input type="checkbox" class="form-check-input" id="reqGas" data-bind="checked: form.requiresGas" />
                        <label class="form-check-label" for="reqGas">Butuh Gas</label>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary me-2" data-bind="click: saveTemplate"><i class="bx bx-check me-1"></i> Simpan</button>
                <button class="btn btn-outline-secondary" data-bind="click: cancelForm">Batal</button>
            </div>
        </div>
    </div>

    <!-- Templates Table -->
    <div class="card">
        <div class="card-header"><h5 class="card-title mb-0">Daftar Template</h5></div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kategori</th>
                        <th>Nama Item</th>
                        <th class="text-center">Urutan</th>
                        <th class="text-center">Gas</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody data-bind="foreach: templates">
                    <tr>
                        <td><span class="badge bg-label-primary" data-bind="text: category"></span></td>
                        <td data-bind="text: name"></td>
                        <td class="text-center" data-bind="text: displayOrder"></td>
                        <td class="text-center">
                            <span class="badge" data-bind="text: requiresGas ? 'Ya' : 'Tidak', css: { 'bg-label-info': requiresGas, 'bg-label-secondary': !requiresGas }"></span>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-icon btn-outline-primary me-1" data-bind="click: $root.editTemplate" title="Edit">
                                <i class="bx bx-edit-alt"></i>
                            </button>
                            <button class="btn btn-sm btn-icon btn-outline-danger" data-bind="click: $root.deleteTemplate" title="Hapus">
                                <i class="bx bx-trash"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div data-bind="visible: templates().length === 0" class="text-center text-muted py-5">
            <i class="bx bx-list-check bx-lg d-block mb-2"></i>
            Belum ada template.
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/knockout")
    <script src="~/Scripts/app/templates.viewmodel.js"></script>
    <script>ko.applyBindings(new TemplatesViewModel(), document.getElementById('templates-page'));</script>
}
