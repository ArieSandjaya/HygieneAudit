<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <compilation targetFramework="4.8" />
    <!-- 50 MB limit for photo uploads (base64-encoded) -->
    <httpRuntime targetFramework="4.8" maxRequestLength="51200" executionTimeout="300" />
  </system.web>
  <system.webServer>
    <!--
      IIS 7: diperlukan agar konfigurasi integrated-mode tidak error saat
      dibaca di classic mode atau saat validasi strict diaktifkan.
    -->
    <validation validateIntegratedModeConfiguration="false" />

    <modules runAllManagedModulesForAllRequests="true">
      <!--
        Hapus native IIS modules yang memblokir request sebelum OWIN:
        - StaticFileModule     : IIS langsung melayani file statis (bypass OWIN)
        - DefaultDocumentModule: IIS mencari default document di app root (bukan wwwroot/)
        - DirectoryListingModule: mencoba list direktori → 403 karena dimatikan
        Dengan menghapus ketiganya, semua request turun ke OWIN pipeline.
      -->
      <remove name="StaticFileModule" />
      <remove name="DefaultDocumentModule" />
      <remove name="DirectoryListingModule" />
    </modules>

    <handlers>
      <!--
        Bersihkan semua handler bawaan IIS, lalu daftarkan satu
        managed handler untuk semua path/verb.
        TransferRequestHandler meneruskan request ke ASP.NET managed pipeline
        di mana OWIN (Microsoft.Owin.Host.SystemWeb) sudah terdaftar sebagai modul.
      -->
      <clear />
      <add name="OwinManagedHandler"
           path="*"
           verb="*"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>

    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
