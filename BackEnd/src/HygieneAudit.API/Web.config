<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <compilation targetFramework="4.8" />
    <!-- 50 MB limit for photo uploads (base64-encoded) -->
    <httpRuntime targetFramework="4.8" maxRequestLength="51200" executionTimeout="300" />
  </system.web>
  <system.webServer>
    <!--
      runAllManagedModulesForAllRequests=true ensures every request
      (including static files and root '/') goes through the OWIN pipeline.
    -->
    <modules runAllManagedModulesForAllRequests="true" />
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <!--
        path="*" (not "*.") catches ALL paths including root '/'
        so OWIN static file middleware can serve index.html.
      -->
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*"
           verb="*"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
    <!-- Prevent IIS from disclosing server version -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
