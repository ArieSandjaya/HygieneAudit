<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <compilation targetFramework="4.8" />
    <!-- 50 MB limit for photo uploads (base64-encoded) -->
    <httpRuntime targetFramework="4.8" maxRequestLength="51200" executionTimeout="300" />
    <!-- Tampilkan detail exception — nonaktifkan setelah masalah solved -->
    <customErrors mode="Off" />
  </system.web>
  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    <!--
      runAllManagedModulesForAllRequests: OwinHttpModule berjalan di BeginRequest
      untuk SEMUA request, sebelum native handler (DirectoryListing dll.) aktif.
      Tidak perlu remove module — selama OWIN startup berhasil, OWIN yang
      melayani request dan native module tidak akan ikut campur.
    -->
    <modules runAllManagedModulesForAllRequests="true" />
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <!--
        path="*." = extensionless URLs (tanpa ekstensi file), termasuk "/" dan "/api/...".
        Jangan pakai path="*" — menyebabkan TransferRequestHandler memanggil dirinya
        sendiri secara rekursif untuk SETIAP request → stack overflow (0x800703e9).
      -->
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*."
           verb="*"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
    <httpErrors errorMode="Detailed" existingResponse="Replace" />
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
